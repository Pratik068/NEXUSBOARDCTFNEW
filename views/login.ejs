<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login – NexusBoard</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="auth-page">
  <div class="auth-box">
    <div class="auth-logo">NexusBoard</div>
    <h2>Sign In</h2>

    <% if (typeof loginErr !== 'undefined' && loginErr) { %>
      <div class="alert-error"><%= loginErr %></div>
    <% } %>

    <% if (typeof sqlError !== 'undefined' && sqlError) { %>
      <div class="alert-sql">
        <div class="sql-label">500 — Internal Server Error</div>
        <pre class="sql-pre"><%= sqlError %></pre>
      </div>
    <% } %>

    <form method="POST" action="/login">
      <div class="field">
        <label>Username</label>
        <input type="text" name="username" autocomplete="off" required>
      </div>
      <div class="field">
        <label>Password</label>
        <input type="password" name="password" required>
      </div>
      <button type="submit" class="btn-primary full">Sign In</button>
    </form>
  </div>
</body>
</html>
