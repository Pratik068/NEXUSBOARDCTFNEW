<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>New Board – NexusBoard</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="app-page">
  <nav class="appnav">
    <div class="brand">NexusBoard</div>
    <div class="nav-links">
      <a href="/dashboard">Dashboard</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
  <div class="app-container narrow">
    <a href="/dashboard" class="back-link">← Back</a>
    <h1>New Board</h1>
    <form method="POST" action="/board/new">
      <div class="field">
        <label>Title</label>
        <input type="text" name="title" required>
      </div>
      <div class="field">
        <label>Content</label>
        <textarea name="content" rows="6"></textarea>
      </div>
      <div class="field">
        <label>Visibility</label>
        <select name="visibility">
          <option value="private">Private</option>
          <option value="public">Public</option>
        </select>
      </div>
      <button type="submit" class="btn-primary">Create Board</button>
    </form>
  </div>
</body>
</html>
