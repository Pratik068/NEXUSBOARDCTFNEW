<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NexusBoard – Team Collaboration</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="landing">
  <nav class="navbar">
    <div class="brand">NexusBoard</div>
    <div class="nav-links">
      <% if (user) { %>
        <a href="/dashboard">Dashboard</a>
        <a href="/logout">Logout</a>
      <% } else { %>
        <a href="/login">Login</a>
      <% } %>
    </div>
  </nav>
  <main class="hero">
    <div class="hero-content">
      <div class="tag">v2.1 — Now with Webhooks</div>
      <h1>Collaborate.<br>Organize.<br>Execute.</h1>
      <p class="sub">NexusBoard is the internal team collaboration platform built for serious teams. Create boards, share notes, and stay in sync.</p>
      <div class="cta-group">
        <a href="/login" class="btn-primary">Sign In</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="floating-card c1"><div class="fc-title">Sprint Board</div><div class="fc-badge member">member</div></div>
      <div class="floating-card c2"><div class="fc-title">Admin Notes</div><div class="fc-badge admin">admin</div></div>
      <div class="floating-card c3"><div class="fc-title">Public Roadmap</div><div class="fc-badge public">public</div></div>
    </div>
  </main>
  <footer class="footer">
    <span>NexusBoard &copy; 2024 — Internal Platform</span>
    <span class="footer-links"><a href="/api/status">Status</a> · <a href="/api/boards/public">Public API</a></span>
  </footer>
</body>
</html>
